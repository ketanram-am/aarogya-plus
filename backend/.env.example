# ── Aarogya+ Backend Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your keys.

# Gemini API key (for prescription OCR)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Places API key (for pharmacy locator — optional, mock used if absent)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Ollama settings (defaults work if Ollama is running locally)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:3b
GEMINI_MODEL=gemini-2.5-flash-lite

# Flask settings
PORT=5000
FLASK_DEBUG=true
